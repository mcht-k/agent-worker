# Agent Runner — API keys and credentials
# Copy this file to .agent/.env and fill in your keys.
# This file is gitignored — secrets never reach the repo.

# ── Anthropic (Claude Code) ──────────────────────────────────────────────────
# Not needed if using Claude Max/Pro subscription (auth stored in ~/.claude/)
# Only needed for API-tier usage (pay per token)
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Codex CLI) ──────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Google (Gemini CLI) ─────────────────────────────────────────────────────
# GOOGLE_API_KEY=AIza...
# or: GEMINI_API_KEY=AIza...

# ── DeepSeek (via Aider) ────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...

# ── xAI / Grok (via Aider) ──────────────────────────────────────────────────
# XAI_API_KEY=xai-...

# ── Notifications ───────────────────────────────────────────────────────────
# NOTIFY_URL=https://ntfy.sh/my-agent-topic
